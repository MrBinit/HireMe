DATABASE_URL=postgresql+asyncpg://postgres:CHANGE_ME@YOUR_RDS_ENDPOINT:5432/hireme
# SQS queue URLs live in YAML config:
# - app/config/parse_config.yaml (parse.queue_url)
# - app/config/evaluation_config.yaml (evaluation.queue_url)
# - app/config/research_config.yaml (research.enrichment.queue_url)
# - app/config/scheduling_config.yaml (scheduling.queue_url)
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
# Optional:
# AWS_SESSION_TOKEN=YOUR_AWS_SESSION_TOKEN
# BEDROCK_ENDPOINT_URL=https://bedrock-runtime.us-east-1.amazonaws.com
SMTP_USERNAME=your-email@example.com
SMTP_PASSWORD=CHANGE_ME
ADMIN_JWT_SECRET=CHANGE_ME_STRONG_RANDOM_STRING_MIN_32_CHARS
# Optional: if omitted, ADMIN_JWT_SECRET is used for interview confirmation links.
# INTERVIEW_CONFIRMATION_TOKEN_SECRET=CHANGE_ME_DIFFERENT_STRONG_RANDOM_STRING
ADMIN_USERNAME=admin
# Use either ADMIN_PASSWORD_HASH (recommended) or ADMIN_PASSWORD (fallback).
# Example hash:
# python -c "from passlib.context import CryptContext;print(CryptContext(schemes=['pbkdf2_sha256'], deprecated='auto').hash('CHANGE_ME'))"
ADMIN_PASSWORD_HASH=$pbkdf2-sha256$REPLACE_WITH_PASSWORD_HASH
# ADMIN_PASSWORD=CHANGE_ME_PLAINTEXT_PASSWORD
REFEREE_USERNAME=referee
# Use either REFEREE_PASSWORD_HASH (recommended) or REFEREE_PASSWORD (fallback).
# Example hash:
# python -c "from passlib.context import CryptContext;print(CryptContext(schemes=['pbkdf2_sha256'], deprecated='auto').hash('CHANGE_ME'))"
REFEREE_PASSWORD_HASH=$pbkdf2-sha256$REPLACE_WITH_REFEREE_PASSWORD_HASH
# REFEREE_PASSWORD=CHANGE_ME_PLAINTEXT_PASSWORD
GOOGLE_CLIENT_ID=YOUR_GOOGLE_OAUTH_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_OAUTH_CLIENT_SECRET
GOOGLE_REFRESH_TOKEN=YOUR_GOOGLE_OAUTH_REFRESH_TOKEN
SERPAPI_API_KEY=YOUR_SERPAPI_API_KEY
GITHUB_API_TOKEN=YOUR_GITHUB_API_TOKEN
TWITTER_CONSUMER_KEY=YOUR_TWITTER_CONSUMER_KEY
TWITTER_CONSUMER_SECRET=YOUR_TWITTER_CONSUMER_SECRET
TWITTER_BEARER_TOKEN=YOUR_TWITTER_BEARER_TOKEN
FIREFLIES_API_KEY=YOUR_FIREFLIES_API_KEY
# Optional direct token fallback:
# DOCUSIGN_ACCESS_TOKEN=YOUR_DOCUSIGN_ACCESS_TOKEN
DOCUSIGN_INTEGRATION_KEY=YOUR_DOCUSIGN_INTEGRATION_KEY
DOCUSIGN_USER_ID=YOUR_DOCUSIGN_USER_ID
# Use one of the following:
DOCUSIGN_PRIVATE_KEY_PATH=./secrets/docusign-private.key
# DOCUSIGN_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
DOCUSIGN_WEBHOOK_SECRET=CHANGE_ME_DOCUSIGN_WEBHOOK_SECRET
SLACK_BOT_TOKEN=xoxb-CHANGE_ME
# Optional admin/user token for workspace invites when required:
# SLACK_ADMIN_USER_TOKEN=xoxp-CHANGE_ME
SLACK_SIGNING_SECRET=CHANGE_ME_SLACK_SIGNING_SECRET
# Optional token rotation (recommended when token expiry is enabled):
# SLACK_CLIENT_ID=CHANGE_ME
# SLACK_CLIENT_SECRET=CHANGE_ME
# SLACK_BOT_REFRESH_TOKEN=xoxe-CHANGE_ME
# SLACK_ADMIN_REFRESH_TOKEN=xoxe-CHANGE_ME
# Optional only for localstack/testing:
# SQS_ENDPOINT_URL=http://localhost:4566
